{
  "mcpServers": {
    "headroom": {
      "command": "uvx",
      "args": ["--from", "headroom-ai==0.26.0", "headroom", "mcp", "serve"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "."]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch==2026.6.4"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@3.2.1"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.76"]
    }
  }
}
